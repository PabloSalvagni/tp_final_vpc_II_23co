# Copiar y completar antes de levantar el stack:
#   cp .env.example .env
#
# Generar una contraseña segura para Postgres:
#   openssl rand -base64 24
#
# IMPORTANTE: .env contiene secretos — no commitear ni compartir por canales inseguros.

POSTGRES_USER=vpc_local
POSTGRES_PASSWORD=
POSTGRES_DB=metricas_db

API_PORT=8000
STREAMLIT_PORT=8501

# Documentación interactiva de la API (/docs). Dejar en false para uso local.
ENABLE_DOCS=false
